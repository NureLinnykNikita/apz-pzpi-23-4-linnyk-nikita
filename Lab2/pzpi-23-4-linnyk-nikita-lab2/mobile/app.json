{
  "expo": {
    "name": "LangBang",
    "slug": "langbang",
    "scheme": "langbang",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#1B1614",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1614"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.langbang.app"
    },
    "android": {
      "package": "com.langbang.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B1614"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://192.168.0.201:5000/api"
    }
  }
}
